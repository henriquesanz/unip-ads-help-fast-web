@page
@model WebAppSuporteIA.Pages.LoginModel
@{
    ViewData["Title"] = "Login - HELP FAST";
    Layout = "_LoginLayout";
}

<div class="login-container">
    <div class="login-card">
        <!-- Logo HELP FAST -->
        <div class="logo-container">
            <div class="logo-text">
                <span class="logo-help">HELP</span>
                <span class="logo-fast">FAST</span>
            </div>
            <div class="logo-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="white"/>
                </svg>
            </div>
        </div>

        <!-- Mensagem de Sucesso -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Mensagem de Erro de Login -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <!-- Formulário de Login -->
        <form method="post" class="login-form">
            <div class="form-group">
                <label for="Email" class="form-label">E-mail</label>
                <div class="input-container">
                    <input asp-for="Email" type="email" class="form-control" placeholder="Digite seu e-mail" />
                    <div class="input-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="#666"/>
                        </svg>
                    </div>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Password" class="form-label">Senha</label>
                <div class="input-container">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Digite sua senha" />
                    <div class="input-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" fill="#666"/>
                        </svg>
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-login">Login</button>
                <div class="separator">OU</div>
                <button type="button" class="btn btn-register" onclick="window.location.href='/Register'">Cadastrar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
