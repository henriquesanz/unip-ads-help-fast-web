@page
@model WebAppSuporteIA.Pages.NovoChamadoModel
@{
    ViewData["Title"] = "Novo Chamado - HELP FAST";
    Layout = "_LoginLayout";
}

<div class="dashboard-container">
    <div class="page-content">
        <div class="page-header">
            <h1 class="page-title">Solicitar Novo Chamado</h1>
            <button type="button" class="btn btn-back" onclick="window.location.href='/Dashboard'">
                ← Voltar ao Dashboard
            </button>
        </div>

        <div class="form-container">
            <form method="post" class="ticket-form">
                <div class="form-group">
                    <label for="Titulo" class="form-label">Título do Chamado</label>
                    <input asp-for="Titulo" type="text" class="form-control" placeholder="Digite o título do seu chamado" />
                    <span asp-validation-for="Titulo" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Descricao" class="form-label">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control" rows="5" placeholder="Descreva detalhadamente o problema ou solicitação"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Prioridade" class="form-label">Prioridade</label>
                    <select asp-for="Prioridade" class="form-control">
                        <option value="">Selecione a prioridade</option>
                        <option value="Baixa">Baixa</option>
                        <option value="Média">Média</option>
                        <option value="Alta">Alta</option>
                        <option value="Crítica">Crítica</option>
                    </select>
                    <span asp-validation-for="Prioridade" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-submit">Criar Chamado</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
